{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "frontend: install",
            "type": "shell",
            "command": "npm install",
            "options": {
                "cwd": "${workspaceFolder}/front/frontend"
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "vite: dev",
            "type": "shell",
            "command": "npm run dev -- --port 9245 --strictPort",
            "options": {
                "cwd": "${workspaceFolder}/front/frontend",
                "env": {
                    "WAILS_VITE_PORT": "9245"
                }
            },
            "isBackground": true,
            "problemMatcher": {
                "owner": "vite",
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "(127\\.0\\.0\\.1:9245|Local:\\s+http://127\\.0\\.0\\.1:9245)"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": false
            }
        },
        {
            "label": "wails3: dev",
            "type": "shell",
            "command": "wails3 dev -config ./build/config.yml -port 9245",
            "options": {
                "cwd": "${workspaceFolder}/front",
                "envFile": "${workspaceFolder}/.env",
                "env": {
                    "WAILS_VITE_PORT": "9245",
                    "EXTRA_TAGS": "dev"
                }
            },
            "isBackground": true,
            "problemMatcher": {
                "owner": "wails",
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "Connected to frontend dev server"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": false
            }
        },
        {
            "label": "wails3: dev stack",
            "dependsOn": [
                "wails3: dev"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "dlv: attach meguri",
            "type": "shell",
            "command": "node \"${workspaceFolder}/.vscode/scripts/dlv-attach-meguri.js\"",
            "isBackground": true,
            "problemMatcher": {
                "owner": "dlv",
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "API server listening at:"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": false
            }
        },
        {
            "label": "dlv: kill",
            "type": "shell",
            "command": "node \"${workspaceFolder}/.vscode/scripts/dlv-kill.js\"",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        }
    ]
}