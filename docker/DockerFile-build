# 「Go 1.26 + Docker-in-Docker + fyne-cross」 ビルド環境を再現する Dockerfile。
#
# 用途: ローカルや CI で fyne-cross を使ったクロスビルドを行うための実行環境。
#
# ビルド例:
#   docker build -f docker/DockerFile-build -t scraper-bot-fyne-cross .
#
# 実行例（Windows 向けクロスビルド）:
#   docker run --privileged --rm \
#       -v "$PWD":/workspace \
#       scraper-bot-fyne-cross \
#       ./scripts/fyne-cross-build.sh windows

FROM golang:1.26-bookworm

ARG FYNE_CROSS_VERSION=v1.6.1

ENV DEBIAN_FRONTEND=noninteractive \
    GOPATH=/go \
    PATH=/go/bin:/usr/local/go/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# 内部で fyne-cross が docker を呼び出せるように Docker (moby) をインストール。
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        git \
        gnupg \
        iptables \
        openssl \
        pigz \
        xz-utils \
        docker.io \
    && rm -rf /var/lib/apt/lists/*

# fyne-cross をインストール。
RUN go install github.com/fyne-io/fyne-cross@${FYNE_CROSS_VERSION}

WORKDIR /workspace

COPY docker/dind-entrypoint.sh /usr/local/bin/dind-entrypoint.sh
RUN chmod +x /usr/local/bin/dind-entrypoint.sh

# コンテナ起動時に dockerd をバックグラウンドで起動し、その後コマンドを実行。
# fyne-cross 自体が Docker daemon を必要とするため必須。
ENTRYPOINT ["/usr/local/bin/dind-entrypoint.sh"]
CMD ["bash"]
